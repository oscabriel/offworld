    ],
    "catalog": {
      "@tailwindcss/vite": "^4.1.8",
      "@tanstack/react-router": "^1.132.31",
      "@tanstack/react-start": "^1.132.31",
      "react": "19.1.0",
      "react-dom": "19.1.0",
      "tailwindcss": "^4.1.3",
      "tailwind-merge": "^3.3.1",
      "vite-tsconfig-paths": "^5.1.4",
