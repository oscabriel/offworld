{
	"name": "offworld",
	"private": true,
	"type": "module",
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"@tailwindcss/vite": "^4.1.17",
			"@tanstack/react-router": "^1.135.0",
			"@tanstack/react-start": "^1.135.0",
			"react": "19.2.0",
			"react-dom": "19.2.0",
			"tailwindcss": "^4.1.17",
			"tailwind-merge": "^3.4.0",
			"vite-tsconfig-paths": "^5.1.4",
			"convex": "^1.29.0",
			"better-auth": "1.3.27",
			"@convex-dev/better-auth": "^0.9.7",
			"@tanstack/react-router-devtools": "^1.135.0",
			"@types/react": "~19.2.2",
			"@types/react-dom": "^19.2.2",
			"@vitejs/plugin-react": "^5.1.0",
			"typescript": "^5.9.3",
			"vite": "^7.2.2",
			"@types/node": "^24.10.0",
			"alchemy": "^0.77.0"
		}
	},
	"scripts": {
		"check": "biome check --write .",
		"ruler:apply": "bunx @intellectronica/ruler@latest apply --local-only",
		"dev": "turbo dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"dev:native": "turbo -F native dev",
		"dev:web": "turbo -F web dev",
		"dev:server": "turbo -F @offworld/backend dev",
		"dev:setup": "turbo -F @offworld/backend dev:setup",
		"deploy:backend": "cd packages/backend && npx convex deploy --yes",
		"deploy:web": "cd apps/web && bun run deploy",
		"deploy:docs": "cd apps/fumadocs && bun run deploy",
		"deploy:all": "bun run deploy:backend && bun run deploy:web && bun run deploy:docs"
	},
	"dependencies": {
		"react-markdown": "^10.1.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.0",
		"@cloudflare/workers-types": "^4.20250822.0",
		"@types/bun": "^1.3.2",
		"@types/node": "^24.10.0",
		"turbo": "^2.5.4"
	},
	"packageManager": "bun@1.3.2"
}
