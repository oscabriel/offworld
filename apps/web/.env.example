# Environment files are managed separately:
# - .env.dev: Development Convex URLs
# - .env.prod: Production Convex URLs
#
# These are used by Alchemy via --env-file flag in package.json scripts

VITE_CONVEX_URL=
VITE_CONVEX_SITE_URL=

# Optional: Sentry DSN for error monitoring
# Get your DSN from https://sentry.io/settings/projects/
VITE_SENTRY_DSN=